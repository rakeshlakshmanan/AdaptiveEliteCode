# Copy this to /opt/elitecode/.env on the VM and fill in real values.

# Supabase — Project URL
# Dashboard → Connect → API Keys → Project URL
SUPABASE_URL=https://your-project.supabase.co

# Supabase — Secret key (used by the backend to bypass RLS)
# Dashboard → Settings → API Keys → Secret keys → reveal and copy
SUPABASE_SERVICE_ROLE_KEY=sb_secret_...

# Supabase — Legacy JWT secret (optional — only needed for old HS256 projects)
# Dashboard → Settings → JWT Keys → Legacy JWT Secret tab
# Leave blank if your project uses the new ECC (P-256) signing keys
SUPABASE_JWT_SECRET=

# Judge0 CE — do not change (runs on localhost, installed by setup.sh)
JUDGE0_URL=http://localhost:2358

# Frontend URL for CORS (no trailing slash)
FRONTEND_URL=https://elite-code-frontend.pages.dev
